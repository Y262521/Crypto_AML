PORT=4001

# MongoDB
MONGO_URI=mongodb://localhost:27017
MONGO_DB=aml_raw
MONGO_FLAT_TX_DB=aml_raw
MONGO_FLAT_TX_COLLECTION=raw_transactions
MONGO_RAW_DB=aml_raw
MONGO_RAW_COLLECTION=raw_blocks
MONGO_PROCESSED_DB=aml_raw
MONGO_PROCESSED_COLLECTION=processed_transactions

# Ethereum RPC
ALCHEMY_RPC=https://eth-mainnet.g.alchemy.com/v2/rGGUSUFNHfTrp5nrkZdH9
ETH_NETWORK=ethereum-mainnet
ETH_START_BLOCK=21000000
ETH_BATCH_SIZE=50

# ETL / transform
BATCH_SIZE_TRANSFORM=100
AML_HIGH_VALUE_THRESHOLD=10.0
STAGING_FOLDER=data/staging
PROCESSED_FOLDER=data/processed

# Databases
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=yona@1221
NEO4J_DATABASE=neo4j
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=root
MYSQL_DB=aml_clean

# Loader / clustering
BATCH_SIZE=1000
NEO4J_BATCH_SIZE=500
LOG_LEVEL=INFO
DBSCAN_EPS=0.6
DBSCAN_MIN_SAMPLES=5
VELOCITY_24H_THRESHOLD=6

# Pipeline schedule: comma-separated hours in UTC (24h format)
# "8,20" = run at 08:00 UTC and 20:00 UTC every day (2 runs/day)
PIPELINE_SCHEDULE_HOURS=8,20
